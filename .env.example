# Copy this file to `.env` for local development.

# Required for Deep Agents orchestration and synthetic seed generation.
OPENAI_API_KEY=sk-...

# Frontend -> backend local development.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional local overrides.
APP_AGENT_MODEL=gpt-5.4-mini
APP_RESPONSES_GENERATION_MODEL=gpt-5.4-mini

# Database:
# - Leave DATABASE_URL unset to use the default local SQLite database at `api/data/app.db`.
# - Set DATABASE_URL for shared or production PostgreSQL.
# Example Supabase pooler connection:
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Optional: Runloop cloud execution.
# RUNLOOP_API_KEY=...
